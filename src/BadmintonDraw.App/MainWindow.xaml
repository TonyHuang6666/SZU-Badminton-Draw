<Window x:Class="BadmintonDraw.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="深大羽协抽签工具" Height="820" Width="1180" MinHeight="680" MinWidth="920"
        Icon="/Assets/szuba-app-icon.ico"
        WindowStartupLocation="CenterScreen"
        Background="#EFE6FF" FontFamily="Microsoft YaHei UI, Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#6D2CC6" />
        <SolidColorBrush x:Key="DeepPrimaryBrush" Color="#3F0878" />
        <SolidColorBrush x:Key="TextBrush" Color="#2B145F" />
        <SolidColorBrush x:Key="MutedBrush" Color="#6F6690" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="LineBrush" Color="#D8C7F4" />

        <Style TargetType="{x:Type Label}">
            <Setter Property="Foreground" Value="#32205F" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#2F2552" />
            <Setter Property="Background" Value="#FBF8FF" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#2F2552" />
            <Setter Property="Background" Value="#FBF8FF" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        </Style>

        <Style x:Key="RoundedButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7A35D2" />
                                <Setter Property="BorderBrush" Value="#7A35D2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4E0B8F" />
                                <Setter Property="BorderBrush" Value="#4E0B8F" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Foreground" Value="{StaticResource DeepPrimaryBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        </Style>

        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="22,8" />
            <Setter Property="Foreground" Value="#4A2A87" />
            <Setter Property="Background" Value="#F1E8FF" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E2D7F5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowHeight" Value="26" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E8DDF7" />
            <Setter Property="AlternatingRowBackground" Value="#FBF8FF" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#EDE1FC" />
            <Setter Property="Foreground" Value="#32116D" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#DED0F3" />
        </Style>

        <Style x:Key="CenteredCellText" TargetType="{x:Type TextBlock}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="CenteredColumnHeader" TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ScheduleRowStyle" TargetType="{x:Type DataGridRow}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUnscheduled}" Value="True">
                    <Setter Property="Background" Value="#FFF1F2" />
                    <Setter Property="Foreground" Value="#7F1D1D" />
                    <Setter Property="ToolTip" Value="{Binding Reason}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#EFE7FF" Offset="0" />
                <GradientStop Color="#F7F1FF" Offset="0.55" />
                <GradientStop Color="#E1D3F7" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="24,20,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelBrush}" CornerRadius="28" Padding="24,10" SnapsToDevicePixels="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="94" />
                        <RowDefinition Height="8" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="82" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="230" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>

                    <Image Grid.Row="0" Grid.Column="0"
                           Source="/Assets/szuba-red-logo.png"
                           Width="72" Height="72"
                           Stretch="Uniform"
                           VerticalAlignment="Center" />

                    <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0">
                        <TextBlock Text="深大羽协抽签工具"
                                   FontSize="34"
                                   FontWeight="Heavy"
                                   Foreground="{StaticResource DeepPrimaryBrush}" />
                        <TextBlock Text="导入 Excel 名单 · 设置赛制 · 自动随机抽签 · 导出可审计抽签结果"
                                   Margin="0,4,0,0"
                                   FontSize="15"
                                   Foreground="{StaticResource MutedBrush}" />
                    </StackPanel>

                    <Button Grid.Row="0" Grid.Column="2"
                            Width="184"
                            Height="46"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Style="{StaticResource RoundedButton}"
                            Click="CreateTemplate_Click">生成名单模板</Button>

                    <Image Grid.Row="0" Grid.Column="3"
                           Source="/Assets/szuba-blue-yellow-logo.png"
                           Width="180"
                           Height="78"
                           Stretch="Uniform"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center" />

                    <Grid Grid.Row="1" Grid.ColumnSpan="4" Height="8" ClipToBounds="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="0.9*" />
                            <ColumnDefinition Width="0.75*" />
                            <ColumnDefinition Width="3.9*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#B00870" CornerRadius="4,0,0,4" />
                        <Border Grid.Column="1" Background="#FFC445" />
                        <Border Grid.Column="2" Background="#4A8DF7" />
                        <Border Grid.Column="3" Background="{StaticResource PrimaryBrush}" CornerRadius="0,4,4,0" />
                    </Grid>
                </Grid>
            </Border>

            <TabControl Grid.Row="2">
                <TabItem Header="抽签与对阵表">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="390" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="22" Padding="28,26">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="抽签设置"
                                       FontSize="24"
                                       FontWeight="Heavy"
                                       Foreground="{StaticResource DeepPrimaryBrush}" />

                            <Label Content="参赛名单 Excel" Margin="0,26,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="76" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="InputPathBox" IsReadOnly="True" />
                                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Click="BrowseInput_Click">选择</Button>
                            </Grid>

                            <Label Content="比赛模式" Margin="0,18,0,8" />
                            <ComboBox x:Name="CompetitionModeBox" SelectionChanged="CompetitionModeBox_SelectionChanged">
                                <ComboBoxItem Content="单项赛（淘汰赛）" Tag="SinglesKnockout" IsSelected="True" />
                                <ComboBoxItem Content="单项赛（循环赛）" Tag="SinglesRoundRobin" />
                                <ComboBoxItem Content="团体赛（淘汰赛）" Tag="TeamKnockout" />
                                <ComboBoxItem Content="团体赛（循环赛）" Tag="TeamRoundRobin" />
                            </ComboBox>

                            <Label Content="项目类型" Margin="0,18,0,8" />
                            <ComboBox x:Name="EventKindBox">
                                <ComboBoxItem Content="单打" Tag="Singles" IsSelected="True" />
                                <ComboBoxItem Content="双打" Tag="Doubles" />
                                <ComboBoxItem Content="团体" Tag="Team" />
                            </ComboBox>

                            <Label Content="小组数" Margin="0,18,0,8" />
                            <TextBox x:Name="GroupCountBox" Text="4" TextChanged="GroupCountBox_TextChanged" />

                            <StackPanel x:Name="KnockoutGoalPanel">
                                <Label Content="淘汰赛目标" Margin="0,18,0,8" />
                                <ComboBox x:Name="KnockoutGoalBox" SelectionChanged="KnockoutGoalBox_SelectionChanged">
                                    <ComboBoxItem Content="每组出线" Tag="OneQualifierPerGroup" IsSelected="True" />
                                    <ComboBoxItem Content="决出冠军" Tag="Champion" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel x:Name="PlacementPlayoffPanel" Visibility="Collapsed">
                                <Label Content="名次附加赛" Margin="0,18,0,8" />
                                <ComboBox x:Name="PlacementPlayoffBox">
                                    <ComboBoxItem Content="不进行附加赛" Tag="None" IsSelected="True" />
                                    <ComboBoxItem Content="只排 3/4 名" Tag="ThirdPlace" />
                                    <ComboBoxItem Content="排 3-8 名" Tag="ThirdToEighth" />
                                </ComboBox>
                            </StackPanel>

                            <Label Content="随机数种子" Margin="0,18,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="76" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SeedBox" />
                                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Click="GenerateSeed_Click">生成</Button>
                            </Grid>

                            <Label Content="导出为" Margin="0,18,0,8" />
                            <ComboBox x:Name="ExportFormatBox" SelectionChanged="ExportFormatBox_SelectionChanged">
                                <ComboBoxItem Content="Excel" Tag="Excel" IsSelected="True" />
                                <ComboBoxItem Content="JPG 图片" Tag="Jpeg" />
                                <ComboBoxItem Content="极清 PNG（透明背景）" Tag="Png" />
                                <ComboBoxItem Content="A4 PDF 打印" Tag="A4Pdf" />
                                <ComboBoxItem Content="全部导出" Tag="All" />
                            </ComboBox>

                            <StackPanel x:Name="A4PdfOptionsPanel" Visibility="Collapsed">
                                <Label Content="A4 PDF 分页" Margin="0,18,0,8" />
                                <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="42" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="行"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center" />
                                <TextBox x:Name="PdfRowsBox" Grid.Column="1" Text="1" />
                                <TextBlock Grid.Column="3"
                                           Text="列"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center" />
                                <TextBox x:Name="PdfColumnsBox" Grid.Column="4" Text="1" />
                                </Grid>
                            </StackPanel>

                            <Button Margin="0,22,0,0"
                                    Style="{StaticResource RoundedButton}"
                                    Background="{StaticResource DeepPrimaryBrush}"
                                    BorderBrush="{StaticResource DeepPrimaryBrush}"
                                    Click="Preview_Click">预览抽签</Button>
                            <Button Margin="0,14,0,0"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="48"
                                    Click="Export_Click">选择路径并导出</Button>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource PanelBrush}" CornerRadius="22" Padding="28,26">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="预览结果"
                                       FontSize="24"
                                       FontWeight="Heavy"
                                       Foreground="{StaticResource DeepPrimaryBrush}" />

                            <WrapPanel Grid.Row="2" ItemHeight="30">
                                <Border Background="#F2E9FF" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="15" Padding="14,6" Margin="0,0,8,0">
                                    <TextBlock x:Name="SummaryText" Text="尚未导入名单。" Foreground="#4B2C83" />
                                </Border>
                                <Border Background="#FFF8E6" BorderBrush="#F2D889" BorderThickness="1" CornerRadius="15" Padding="14,6" Margin="0,0,8,0">
                                    <TextBlock x:Name="ParticipantPillText" Text="参赛单位 0 个" Foreground="#7B5600" />
                                </Border>
                                <Border Background="#EAF3FF" BorderBrush="#B7D3FF" BorderThickness="1" CornerRadius="15" Padding="14,6">
                                    <TextBlock x:Name="SeedPillText" Text="随机数种子：未生成" Foreground="#235494" />
                                </Border>
                            </WrapPanel>
                        </Grid>

                        <TabControl Grid.Row="2">
                            <TabItem Header="总分组">
                                <DataGrid x:Name="GroupsGrid" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="组别" Binding="{Binding GroupName}" Width="110" />
                                        <DataGridTextColumn Header="组内序号" Binding="{Binding Order}" Width="110" />
                                        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="种子" Binding="{Binding SeedLabel}" Width="100"
                                                            ElementStyle="{StaticResource CenteredCellText}"
                                                            HeaderStyle="{StaticResource CenteredColumnHeader}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="第一轮">
                                <DataGrid x:Name="RoundOneGrid" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="组别" Binding="{Binding GroupName}" Width="110" />
                                        <DataGridTextColumn Header="组内序号" Binding="{Binding Order}" Width="110" />
                                        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="种子" Binding="{Binding SeedLabel}" Width="100"
                                                            ElementStyle="{StaticResource CenteredCellText}"
                                                            HeaderStyle="{StaticResource CenteredColumnHeader}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="轮空/晋级">
                                <DataGrid x:Name="ByeGrid" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="组别" Binding="{Binding GroupName}" Width="110" />
                                        <DataGridTextColumn Header="组内序号" Binding="{Binding Order}" Width="110" />
                                        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="种子" Binding="{Binding SeedLabel}" Width="100"
                                                            ElementStyle="{StaticResource CenteredCellText}"
                                                            HeaderStyle="{StaticResource CenteredColumnHeader}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                        </TabControl>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Background="#FBF8FF" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10" Padding="16,10">
                                <StackPanel>
                                    <TextBlock Text="参赛人数" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                    <TextBlock x:Name="ParticipantCountText" Text="0" Foreground="{StaticResource DeepPrimaryBrush}" FontWeight="Heavy" FontSize="21" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="#FBF8FF" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10" Padding="16,10">
                                <StackPanel>
                                    <TextBlock Text="项目类型" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                    <TextBlock x:Name="EventKindStatText" Text="单打" Foreground="{StaticResource DeepPrimaryBrush}" FontWeight="Heavy" FontSize="21" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="4" Background="#FBF8FF" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10" Padding="16,10">
                                <StackPanel>
                                    <TextBlock Text="小组数" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                    <TextBlock x:Name="GroupCountStatText" Text="4" Foreground="{StaticResource DeepPrimaryBrush}" FontWeight="Heavy" FontSize="21" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="6" Background="#FBF8FF" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10" Padding="16,10">
                                <StackPanel>
                                    <TextBlock Text="状态" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                    <TextBlock x:Name="PreviewStateText" Text="未预览" Foreground="{StaticResource DeepPrimaryBrush}" FontWeight="Heavy" FontSize="21" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
                </TabItem>

                <TabItem Header="赛程编排">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="390" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="22" Padding="28,26">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="赛程编排"
                                               FontSize="24"
                                               FontWeight="Heavy"
                                               Foreground="{StaticResource DeepPrimaryBrush}" />

                                    <Border Margin="0,18,0,4"
                                            Padding="12"
                                            Background="#F7F3FF"
                                            BorderBrush="{StaticResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock x:Name="ProgressFileText"
                                                       Text="尚未创建或打开赛事存档"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       TextWrapping="Wrap" />
                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button Style="{StaticResource SecondaryButton}"
                                                        Click="CreateProgress_Click">创建赛事存档</Button>
                                                <Button Grid.Column="2"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Click="OpenProgress_Click">打开赛事存档</Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Label Content="预约日期" Margin="0,26,0,8" />
                                    <DatePicker x:Name="ScheduleDatePicker" Height="44" />

                                    <Label Content="预约时间段" Margin="0,18,0,8" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="ScheduleStartBox">
                                            <ComboBoxItem Content="08:00" />
                                            <ComboBoxItem Content="09:00" />
                                            <ComboBoxItem Content="10:00" />
                                            <ComboBoxItem Content="11:00" />
                                            <ComboBoxItem Content="12:00" />
                                            <ComboBoxItem Content="13:00" />
                                            <ComboBoxItem Content="14:00" IsSelected="True" />
                                            <ComboBoxItem Content="15:00" />
                                            <ComboBoxItem Content="16:00" />
                                            <ComboBoxItem Content="17:00" />
                                            <ComboBoxItem Content="18:00" />
                                            <ComboBoxItem Content="19:00" />
                                            <ComboBoxItem Content="20:00" />
                                            <ComboBoxItem Content="21:00" />
                                        </ComboBox>
                                        <ComboBox x:Name="ScheduleEndBox" Grid.Column="2">
                                            <ComboBoxItem Content="09:00" />
                                            <ComboBoxItem Content="10:00" />
                                            <ComboBoxItem Content="11:00" />
                                            <ComboBoxItem Content="12:00" />
                                            <ComboBoxItem Content="13:00" />
                                            <ComboBoxItem Content="14:00" />
                                            <ComboBoxItem Content="15:00" />
                                            <ComboBoxItem Content="16:00" />
                                            <ComboBoxItem Content="17:00" />
                                            <ComboBoxItem Content="18:00" IsSelected="True" />
                                            <ComboBoxItem Content="19:00" />
                                            <ComboBoxItem Content="20:00" />
                                            <ComboBoxItem Content="21:00" />
                                            <ComboBoxItem Content="22:00" />
                                        </ComboBox>
                                    </Grid>

                                    <Label Content="选择场馆" Margin="0,18,0,8" />
                                    <ComboBox x:Name="ScheduleVenueBox" SelectionChanged="ScheduleVenueBox_SelectionChanged">
                                        <ComboBoxItem Content="全部" Tag="All" />
                                        <ComboBoxItem Content="运动广场东馆羽毛球场" Tag="YuehaiEast" IsSelected="True" />
                                        <ComboBoxItem Content="至快体育馆" Tag="Zhikuai" />
                                        <ComboBoxItem Content="至畅体育馆" Tag="Zhichang" />
                                        <ComboBoxItem Content="自定义场地" Tag="Custom" />
                                    </ComboBox>

                                    <Label Content="选择场地（逗号分隔，可手动删改）" Margin="0,18,0,8" />
                                    <TextBox x:Name="ScheduleCourtsBox"
                                             Height="118"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalContentAlignment="Top"
                                             Padding="12,8" />

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Style="{StaticResource RoundedButton}"
                                                Background="#235494"
                                                BorderBrush="#235494"
                                                Click="AddScheduleDay_Click">添加赛程日</Button>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="RemoveScheduleDay_Click">删除选中赛程日</Button>
                                    </Grid>

                                    <DataGrid x:Name="ScheduleDaysGrid"
                                              Height="150"
                                              Margin="0,14,0,0"
                                              AutoGenerateColumns="False"
                                              SelectionMode="Single">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="日期" Binding="{Binding Date}" Width="96" />
                                            <DataGridTextColumn Header="时间段" Binding="{Binding TimeRange}" Width="110" />
                                            <DataGridTextColumn Header="场馆" Binding="{Binding Venue}" Width="130" />
                                            <DataGridTextColumn Header="场地" Binding="{Binding CourtSummary}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <StackPanel x:Name="ScheduleTimingSplitPanel">
                                        <Label Content="淘汰赛赛程分界线" Margin="0,18,0,8" />
                                        <ComboBox x:Name="ScheduleTimingBoundaryBox">
                                            <ComboBoxItem Content="不分段（统一设置）" Tag="0" />
                                            <ComboBoxItem Content="4强" Tag="4" />
                                            <ComboBoxItem Content="8强" Tag="8" IsSelected="True" />
                                            <ComboBoxItem Content="16强" Tag="16" />
                                        </ComboBox>

                                        <Label Content="分界线前设置" Margin="0,18,0,8" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="62" />
                                                <ColumnDefinition Width="78" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="每场"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBox x:Name="BeforeBoundaryMatchMinutesBox" Grid.Column="1" Text="20" />
                                            <TextBlock Grid.Column="3"
                                                       Text="每日最多"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       VerticalAlignment="Center" />
                                            <ComboBox x:Name="BeforeBoundaryMaxMatchesPerDayBox" Grid.Column="4">
                                                <ComboBoxItem Content="1" />
                                                <ComboBoxItem Content="2" />
                                                <ComboBoxItem Content="3" IsSelected="True" />
                                                <ComboBoxItem Content="4" />
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>

                                    <Label x:Name="ScheduleDefaultTimingLabel" Content="分界线后设置" Margin="0,18,0,8" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="62" />
                                            <ColumnDefinition Width="78" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="每场"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBox x:Name="ScheduleMatchMinutesBox" Grid.Column="1" Text="30" />
                                        <TextBlock Grid.Column="3"
                                                   Text="每日最多"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   VerticalAlignment="Center" />
                                        <ComboBox x:Name="MaxMatchesPerDayBox" Grid.Column="4">
                                            <ComboBoxItem Content="1" />
                                            <ComboBoxItem Content="2" IsSelected="True" />
                                            <ComboBoxItem Content="3" />
                                        </ComboBox>
                                    </Grid>

                                    <Button Margin="0,22,0,0"
                                            Style="{StaticResource RoundedButton}"
                                            Background="#235494"
                                            BorderBrush="#235494"
                                            Click="GenerateSchedule_Click">生成赛程预览</Button>
                                    <Button Margin="0,10,0,0"
                                            Style="{StaticResource SecondaryButton}"
                                            Height="48"
                                            Click="ExportFirstDayPackage_Click">导出首日材料包</Button>
                                    <Button Margin="0,10,0,0"
                                            Style="{StaticResource SecondaryButton}"
                                            Height="48"
                                            Click="ImportMatchRecordAndExportNext_Click">导入记录表并导出下一日材料包</Button>
                                    <Label Content="完整赛程表导出为" Margin="0,18,0,8" />
                                    <ComboBox x:Name="ScheduleExportFormatBox">
                                        <ComboBoxItem Content="Excel" Tag="Excel" IsSelected="True" />
                                        <ComboBoxItem Content="JPG 图片" Tag="Jpeg" />
                                        <ComboBoxItem Content="极清 PNG（透明背景）" Tag="Png" />
                                        <ComboBoxItem Content="A4 PDF 打印" Tag="A4Pdf" />
                                        <ComboBoxItem Content="全部导出" Tag="All" />
                                    </ComboBox>
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{StaticResource MutedBrush}"
                                               TextWrapping="Wrap"
                                               Text="材料包会固定包含记录表、赛程安排表、带时间场地对阵表和单场计分表 PDF（每场一页横版）；这里的格式只用于完整赛程表单文件导出。" />
                                    <Button Margin="0,14,0,0"
                                            Style="{StaticResource SecondaryButton}"
                                            Height="48"
                                            Click="ExportSchedule_Click">导出完整赛程表</Button>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="2" Background="{StaticResource PanelBrush}" CornerRadius="22" Padding="28,26">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="赛程预览"
                                               FontSize="24"
                                               FontWeight="Heavy"
                                               Foreground="{StaticResource DeepPrimaryBrush}" />
                                    <WrapPanel Grid.Row="2" ItemHeight="30">
                                        <Border Background="#EAF3FF" BorderBrush="#B7D3FF" BorderThickness="1" CornerRadius="15" Padding="14,6" Margin="0,0,8,0">
                                            <TextBlock x:Name="ScheduleSummaryText" Text="尚未生成赛程。" Foreground="#235494" />
                                        </Border>
                                        <Border Background="#FFF8E6" BorderBrush="#F2D889" BorderThickness="1" CornerRadius="15" Padding="14,6">
                                            <TextBlock x:Name="ScheduleCapacityText" Text="待选择日期、时间段与场地" Foreground="#7B5600" />
                                        </Border>
                                    </WrapPanel>
                                </Grid>

                                <DataGrid Grid.Row="2" x:Name="ScheduleGrid" AutoGenerateColumns="False" RowStyle="{StaticResource ScheduleRowStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="序号" Binding="{Binding Order}" Width="70" />
                                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90" />
                                        <DataGridTextColumn Header="日期/比赛日" Binding="{Binding DayLabel}" Width="120" />
                                        <DataGridTextColumn Header="时间" Binding="{Binding TimeRange}" Width="120" />
                                        <DataGridTextColumn Header="场地" Binding="{Binding Court}" Width="110" />
                                        <DataGridTextColumn Header="组别" Binding="{Binding GroupName}" Width="90" />
                                        <DataGridTextColumn Header="阶段" Binding="{Binding Phase}" Width="120" />
                                        <DataGridTextColumn Header="场次" Binding="{Binding MatchName}" Width="170" />
                                        <DataGridTextColumn Header="选手/队伍A" Binding="{Binding SideA}" Width="*" />
                                        <DataGridTextColumn Header="选手/队伍B" Binding="{Binding SideB}" Width="*" />
                                        <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="150" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <Border Grid.Row="4" Background="#F6F0FF" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="18" Padding="18,10">
                <DockPanel LastChildFill="False">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="#19B77A" VerticalAlignment="Center" />
                        <TextBlock x:Name="StatusText" Text="准备就绪。" Margin="10,0,0,0" Foreground="#5A4B7E" VerticalAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Right"
                               Text="作者微信：Tony_Huang1229    深大羽协官方微信：SZUbadminton    GitHub：TonyHuang6666"
                               Foreground="{StaticResource DeepPrimaryBrush}"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
