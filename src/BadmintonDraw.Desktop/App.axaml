<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BadmintonDraw.Desktop.App"
             RequestedThemeVariant="Light">
             <!-- The current UI uses explicit light surfaces; keep Avalonia controls in light mode even when the OS is dark. -->

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
