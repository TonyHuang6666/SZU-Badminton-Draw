<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BadmintonDraw.Desktop.MainWindow"
        Title="深大羽协抽签工具 - macOS 预览版"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="660"
        WindowStartupLocation="CenterScreen">
    <Window.Styles>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#33106B" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#4A3A68" />
            <Setter Property="Margin" Value="0,12,0,6" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#295C9A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="14,9" />
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Padding" Value="14,9" />
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDCEFA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
        </Style>
    </Window.Styles>

    <Grid Background="#F2ECFF" RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" Background="White" Padding="24,18" BorderBrush="#E4D7FA" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="深大羽协抽签工具" FontSize="30" FontWeight="Bold" Foreground="#33106B" />
                    <TextBlock Text="macOS / Windows / Linux 跨平台预览版：名单导入、抽签预览、基础赛程、Excel 导出"
                               Foreground="#6C5C8F" Margin="0,6,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="Avalonia Desktop"
                           VerticalAlignment="Center"
                           Foreground="#295C9A"
                           FontWeight="Bold" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="390,*" Margin="24" ColumnSpacing="18">
            <Border Classes="panel" Grid.Column="0">
                <ScrollViewer>
                    <StackPanel Spacing="0">
                        <TextBlock Classes="section-title" Text="抽签设置" />

                        <TextBlock Classes="label" Text="参赛名单 Excel" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox x:Name="InputPathBox" PlaceholderText="请选择 .xlsx 参赛名单" />
                            <Button Grid.Column="1" Classes="secondary" Content="选择" Click="BrowseInput_Click" />
                        </Grid>

                        <Button Classes="secondary"
                                Content="生成名单模板"
                                Margin="0,10,0,0"
                                Click="CreateTemplate_Click" />

                        <TextBlock Classes="label" Text="比赛模式" />
                        <ComboBox x:Name="CompetitionModeBox" SelectedIndex="0">
                            <ComboBoxItem Content="单项赛淘汰赛" />
                            <ComboBoxItem Content="单项赛循环赛" />
                            <ComboBoxItem Content="团体赛淘汰赛" />
                            <ComboBoxItem Content="团体赛循环赛" />
                        </ComboBox>

                        <TextBlock Classes="label" Text="项目类型" />
                        <ComboBox x:Name="EventKindBox" SelectedIndex="1">
                            <ComboBoxItem Content="单打" />
                            <ComboBoxItem Content="双打" />
                            <ComboBoxItem Content="团体" />
                        </ComboBox>

                        <TextBlock Classes="label" Text="小组数" />
                        <TextBox x:Name="GroupCountBox" Text="8" />

                        <TextBlock Classes="label" Text="淘汰赛目标" />
                        <ComboBox x:Name="KnockoutGoalBox" SelectedIndex="0">
                            <ComboBoxItem Content="每组出线" />
                            <ComboBoxItem Content="决出冠军" />
                        </ComboBox>

                        <TextBlock Classes="label" Text="名次附加赛" />
                        <ComboBox x:Name="PlacementPlayoffBox" SelectedIndex="0">
                            <ComboBoxItem Content="不排附加赛" />
                            <ComboBoxItem Content="排 3/4 名赛" />
                            <ComboBoxItem Content="排 3-8 名赛" />
                        </ComboBox>

                        <TextBlock Classes="label" Text="随机数种子" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox x:Name="SeedBox" />
                            <Button Grid.Column="1" Classes="secondary" Content="重生成" Click="GenerateSeed_Click" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,18,0,0">
                            <Button Classes="primary" Content="预览抽签" Click="Preview_Click" />
                            <Button Grid.Column="1" Classes="secondary" Content="导出 Excel" Click="Export_Click" />
                        </Grid>

                        <Border Height="1" Background="#E7DCF9" Margin="0,22,0,6" />
                        <TextBlock Classes="section-title" Text="赛程编排" />

                        <TextBlock Classes="label" Text="比赛日期" />
                        <TextBox x:Name="ScheduleDateBox" PlaceholderText="yyyy-MM-dd" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <StackPanel>
                                <TextBlock Classes="label" Text="开始时间" />
                                <TextBox x:Name="ScheduleStartBox" Text="14:00" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Classes="label" Text="结束时间" />
                                <TextBox x:Name="ScheduleEndBox" Text="18:00" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Classes="label" Text="场地" />
                        <TextBox x:Name="ScheduleCourtsBox"
                                 Text="B1-B8 C1-C8"
                                 AcceptsReturn="True"
                                 MinHeight="56"
                                 TextWrapping="Wrap" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <StackPanel>
                                <TextBlock Classes="label" Text="每场分钟" />
                                <TextBox x:Name="ScheduleMatchMinutesBox" Text="30" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Classes="label" Text="每日最多场" />
                                <TextBox x:Name="ScheduleMaxMatchesBox" Text="2" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,18,0,0">
                            <Button Classes="primary" Content="生成赛程" Click="GenerateSchedule_Click" />
                            <Button Grid.Column="1" Classes="secondary" Content="导出赛程" Click="ExportSchedule_Click" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Classes="panel" Grid.Column="1">
                <Grid RowDefinitions="Auto,Auto,*">
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                        <Border Background="#EEF6FF" CornerRadius="8" Padding="14">
                            <StackPanel>
                                <TextBlock Text="参赛单位" Foreground="#506070" />
                                <TextBlock x:Name="ParticipantCountText" Text="-" FontSize="24" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="#F1F8EF" CornerRadius="8" Padding="14">
                            <StackPanel>
                                <TextBlock Text="小组数" Foreground="#506070" />
                                <TextBlock x:Name="GroupCountStatText" Text="-" FontSize="24" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#FFF7E6" CornerRadius="8" Padding="14">
                            <StackPanel>
                                <TextBlock Text="项目" Foreground="#506070" />
                                <TextBlock x:Name="EventKindStatText" Text="-" FontSize="24" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Background="#F5EEFF" CornerRadius="8" Padding="14">
                            <StackPanel>
                                <TextBlock Text="状态" Foreground="#506070" />
                                <TextBlock x:Name="PreviewStateText" Text="待预览" FontSize="24" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="0,18,0,12">
                        <TextBlock x:Name="SummaryText" Classes="section-title" Text="尚未生成抽签预览" />
                        <TextBlock x:Name="WarningText" Foreground="#8A5B00" TextWrapping="Wrap" Margin="0,6,0,0" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="2">
                        <StackPanel Spacing="14">
                            <TextBlock Classes="section-title" Text="总分组" />
                            <ItemsControl x:Name="GroupsList" />

                            <TextBlock Classes="section-title" Text="首轮赛" />
                            <ItemsControl x:Name="RoundOneList" />

                            <TextBlock Classes="section-title" Text="轮空 / 直接晋级" />
                            <ItemsControl x:Name="ByeList" />

                            <TextBlock Classes="section-title" Text="赛程预览" />
                            <TextBlock x:Name="ScheduleSummaryText"
                                       Text="尚未生成赛程"
                                       Foreground="#4A3A68"
                                       TextWrapping="Wrap" />
                            <ItemsControl x:Name="ScheduleList" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="#E4D7FA" BorderThickness="0,1,0,0" Padding="24,10">
            <TextBlock x:Name="StatusText"
                       Text="准备就绪。macOS 版已接入名单模板、名单导入、抽签预览、基础赛程和 Excel 导出。"
                       Foreground="#5A4B7E"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
