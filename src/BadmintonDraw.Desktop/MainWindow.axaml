<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BadmintonDraw.Desktop.MainWindow"
        x:CompileBindings="False"
        Title="深大羽协抽签工具 - 跨平台桌面版"
        Width="1180"
        Height="760"
        MinWidth="1040"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        FontFamily="Inter, PingFang SC, Microsoft YaHei UI, Segoe UI">
    <Window.Styles>
        <Style Selector="TextBlock.app-title">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#28104E" />
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#28104E" />
        </Style>
        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#4D4366" />
            <Setter Property="Margin" Value="0,10,0,5" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#6F7890" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="#FBFCFF" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Foreground" Value="#111827" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Background" Value="#FBFCFF" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Foreground" Value="#111827" />
        </Style>
        <Style Selector="ComboBox:pointerover">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#93C5FD" />
            <Setter Property="Foreground" Value="#111827" />
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Foreground" Value="#111827" />
        </Style>
        <Style Selector="ComboBoxItem:pointerover">
            <Setter Property="Background" Value="#EFF6FF" />
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>
        <Style Selector="ComboBoxItem:selected">
            <Setter Property="Background" Value="#DBEAFE" />
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>
        <Style Selector="Button">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#0F5F9F" />
            <Setter Property="BorderBrush" Value="#0F5F9F" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#0B548D" />
            <Setter Property="BorderBrush" Value="#0B548D" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#C7D2E4" />
            <Setter Property="Foreground" Value="#243B63" />
        </Style>
        <Style Selector="Button.secondary:pointerover">
            <Setter Property="Background" Value="#F1F7FF" />
            <Setter Property="BorderBrush" Value="#93B9E8" />
            <Setter Property="Foreground" Value="#17345D" />
        </Style>
        <Style Selector="Button.subtle">
            <Setter Property="Background" Value="#F4F7FB" />
            <Setter Property="BorderBrush" Value="#D9E2EF" />
            <Setter Property="Foreground" Value="#344767" />
        </Style>
        <Style Selector="Button.subtle:pointerover">
            <Setter Property="Background" Value="#EAF1FA" />
            <Setter Property="BorderBrush" Value="#C2D1E5" />
            <Setter Property="Foreground" Value="#243B63" />
        </Style>
        <Style Selector="Button.compact">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="12,8" />
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D8E0EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Border.metric">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border.preview-row">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#3F315F" />
        </Style>
        <Style Selector="TabItem:pointerover">
            <Setter Property="Foreground" Value="#111827" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="#111827" />
        </Style>
    </Window.Styles>

    <Grid Background="#F5F7FB" RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#DCE3EF"
                BorderThickness="0,0,0,1"
                Padding="26,18,26,0">
            <Grid RowDefinitions="Auto,Auto">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="14">
                    <Border Width="62"
                            Height="62"
                            CornerRadius="12"
                            Background="#FFFFFF"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            Padding="4">
                        <Image Source="avares://BadmintonDraw.Desktop/Assets/szuba-red-logo.png"
                               Stretch="Uniform" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                        <TextBlock Classes="app-title" Text="深大羽协抽签工具" />
                        <TextBlock Classes="muted"
                                   Text="跨平台桌面版 · 深圳大学羽毛球赛事工作台"
                                   FontSize="14" />
                    </StackPanel>
                    <Image Grid.Column="2"
                           Source="avares://BadmintonDraw.Desktop/Assets/szuba-blue-yellow-logo.png"
                           Width="150"
                           Height="58"
                           Stretch="Uniform"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center" />
                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="8">
                        <Border Background="#EEF6FF" BorderBrush="#C8DEF7" BorderThickness="1" CornerRadius="8" Padding="10,6">
                            <TextBlock Text="跨平台桌面版" Foreground="#0F5F9F" FontWeight="SemiBold" />
                        </Border>
                        <Border Background="#F7F3FF" BorderBrush="#DED2F8" BorderThickness="1" CornerRadius="8" Padding="10,6">
                            <TextBlock Text="Avalonia" Foreground="#4A1E78" FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Height="4" Margin="0,16,0,0" ColumnDefinitions="2*,1.5*,1.4*,5*">
                    <Border Background="#C01268" />
                    <Border Grid.Column="1" Background="#F4B83D" />
                    <Border Grid.Column="2" Background="#3F8BEF" />
                    <Border Grid.Column="3" Background="#6D2CC6" />
                </Grid>
            </Grid>
        </Border>

        <Grid x:Name="MainWorkspaceGrid" Grid.Row="1" ColumnDefinitions="420,*" Margin="22" ColumnSpacing="18">
            <Border x:Name="LeftWorkspacePanel" Classes="panel" Grid.Column="0">
                <Grid RowDefinitions="Auto,*">
                    <Border Background="#FBFCFF"
                            BorderBrush="#E3E9F3"
                            BorderThickness="0,0,0,1"
                            Padding="18,16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="3">
                                <TextBlock Classes="section-title" Text="赛事配置" />
                                <TextBlock Classes="muted" Text="抽签与赛程" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Background="#EFF6F2"
                                    BorderBrush="#CFE5D7"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,6"
                                    VerticalAlignment="Center">
                                <TextBlock Text="本地生成" Foreground="#25654A" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                    </Border>

                    <TabControl Grid.Row="1" Margin="16,12,16,16">
                        <TabItem Header="抽签">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="4" Margin="0,10,0,0">
                                    <TextBlock Classes="field-label" Text="参赛名单 Excel" />
                                    <Grid ColumnDefinitions="*,82" ColumnSpacing="8">
                                        <TextBox x:Name="InputPathBox" PlaceholderText="请选择 .xlsx 参赛名单" />
                                        <Button Grid.Column="1" Classes="secondary compact" Content="选择" Click="BrowseInput_Click" />
                                    </Grid>

                                    <Grid ColumnDefinitions="1.05*,1.45*" ColumnSpacing="8" Margin="0,8,0,6">
                                        <Button Classes="subtle"
                                                Content="生成名单模板"
                                                Click="CreateTemplate_Click" />
                                        <Button Grid.Column="1"
                                                Classes="secondary compact"
                                                Content="浏览参赛选手/队伍信息"
                                                Click="BrowseParticipants_Click" />
                                    </Grid>

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <StackPanel>
                                            <TextBlock Classes="field-label" Text="比赛模式" />
                                            <ComboBox x:Name="CompetitionModeBox"
                                                      SelectedIndex="0"
                                                      SelectionChanged="CompetitionModeBox_SelectionChanged">
                                                <ComboBoxItem Content="单项赛淘汰赛" />
                                                <ComboBoxItem Content="单项赛循环赛" />
                                                <ComboBoxItem Content="团体赛淘汰赛" />
                                                <ComboBoxItem Content="团体赛循环赛" />
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Classes="field-label" Text="项目类型" />
                                            <ComboBox x:Name="EventKindBox" SelectedIndex="1">
                                                <ComboBoxItem Content="单打" />
                                                <ComboBoxItem Content="双打" />
                                                <ComboBoxItem Content="团体" />
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="1.05*,1.45*" ColumnSpacing="10">
                                        <StackPanel>
                                            <TextBlock Classes="field-label" Text="小组数" />
                                            <TextBox x:Name="GroupCountBox"
                                                     Text="8"
                                                     TextChanged="GroupCountBox_TextChanged" />
                                        </StackPanel>
                                        <StackPanel x:Name="KnockoutGoalPanel" Grid.Column="1">
                                            <TextBlock Classes="field-label" Text="淘汰赛目标" />
                                            <ComboBox x:Name="KnockoutGoalBox"
                                                      SelectedIndex="0"
                                                      SelectionChanged="KnockoutGoalBox_SelectionChanged">
                                                <ComboBoxItem Content="每组出线" />
                                                <ComboBoxItem Content="决出冠军" />
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel x:Name="PlacementPlayoffPanel">
                                        <TextBlock Classes="field-label" Text="名次附加赛" />
                                        <ComboBox x:Name="PlacementPlayoffBox" SelectedIndex="0">
                                            <ComboBoxItem Content="不排附加赛" />
                                            <ComboBoxItem Content="排 3/4 名赛" />
                                            <ComboBoxItem Content="排 3-8 名赛" />
                                        </ComboBox>
                                    </StackPanel>

                                    <TextBlock Classes="field-label" Text="随机数种子" />
                                    <Grid ColumnDefinitions="*,92" ColumnSpacing="8">
                                        <TextBox x:Name="SeedBox" />
                                        <Button Grid.Column="1" Classes="secondary compact" Content="重生成" Click="GenerateSeed_Click" />
                                    </Grid>

                                    <Grid ColumnDefinitions="1.35*,*,*" ColumnSpacing="10">
                                        <StackPanel>
                                            <TextBlock Classes="field-label" Text="导出为" />
                                            <ComboBox x:Name="DrawExportFormatBox"
                                                      SelectedIndex="0"
                                                      SelectionChanged="DrawExportFormatBox_SelectionChanged">
                                                <ComboBoxItem Content="Excel" Tag="Excel" />
                                                <ComboBoxItem Content="JPG" Tag="Jpeg" />
                                                <ComboBoxItem Content="极清透明 PNG" Tag="Png" />
                                                <ComboBoxItem Content="A4 PDF" Tag="A4Pdf" />
                                                <ComboBoxItem Content="全部导出" Tag="All" />
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel x:Name="DrawPdfRowsPanel" Grid.Column="1" IsVisible="False">
                                            <TextBlock Classes="field-label" Text="PDF 行" />
                                            <TextBox x:Name="PdfRowsBox" Text="1" />
                                        </StackPanel>
                                        <StackPanel x:Name="DrawPdfColumnsPanel" Grid.Column="2" IsVisible="False">
                                            <TextBlock Classes="field-label" Text="PDF 列" />
                                            <TextBox x:Name="PdfColumnsBox" Text="1" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,16,0,0">
                                        <Button Classes="primary" Content="预览抽签" Click="Preview_Click" />
                                        <Button Grid.Column="1" Classes="secondary" Content="选择路径并导出" Click="Export_Click" />
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="赛程">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="4" Margin="0,10,0,0">
                                    <Border Background="#F7F3FF"
                                            BorderBrush="#DED2F8"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <StackPanel Spacing="10">
                                            <TextBlock x:Name="ProgressFileText"
                                                       Text="尚未创建或打开赛事存档"
                                                       Foreground="#5F5577"
                                                       TextWrapping="Wrap" />
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                                <Button Classes="secondary"
                                                        Content="创建赛事存档"
                                                        Click="CreateProgress_Click" />
                                                <Button Grid.Column="1"
                                                        Classes="secondary"
                                                        Content="打开赛事存档"
                                                        Click="OpenProgress_Click" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Classes="field-label" Text="比赛日期" />
                                    <DatePicker x:Name="ScheduleDatePicker" />

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <StackPanel>
                                            <TextBlock Classes="field-label" Text="开始时间" />
                                            <ComboBox x:Name="ScheduleStartBox" SelectedIndex="6">
                                                <ComboBoxItem Content="08:00" />
                                                <ComboBoxItem Content="09:00" />
                                                <ComboBoxItem Content="10:00" />
                                                <ComboBoxItem Content="11:00" />
                                                <ComboBoxItem Content="12:00" />
                                                <ComboBoxItem Content="13:00" />
                                                <ComboBoxItem Content="14:00" />
                                                <ComboBoxItem Content="15:00" />
                                                <ComboBoxItem Content="16:00" />
                                                <ComboBoxItem Content="17:00" />
                                                <ComboBoxItem Content="18:00" />
                                                <ComboBoxItem Content="19:00" />
                                                <ComboBoxItem Content="20:00" />
                                                <ComboBoxItem Content="21:00" />
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Classes="field-label" Text="结束时间" />
                                            <ComboBox x:Name="ScheduleEndBox" SelectedIndex="9">
                                                <ComboBoxItem Content="09:00" />
                                                <ComboBoxItem Content="10:00" />
                                                <ComboBoxItem Content="11:00" />
                                                <ComboBoxItem Content="12:00" />
                                                <ComboBoxItem Content="13:00" />
                                                <ComboBoxItem Content="14:00" />
                                                <ComboBoxItem Content="15:00" />
                                                <ComboBoxItem Content="16:00" />
                                                <ComboBoxItem Content="17:00" />
                                                <ComboBoxItem Content="18:00" />
                                                <ComboBoxItem Content="19:00" />
                                                <ComboBoxItem Content="20:00" />
                                                <ComboBoxItem Content="21:00" />
                                                <ComboBoxItem Content="22:00" />
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Classes="field-label" Text="选择场馆" />
                                    <ComboBox x:Name="ScheduleVenueBox"
                                              SelectedIndex="0"
                                              SelectionChanged="ScheduleVenueBox_SelectionChanged">
                                        <ComboBoxItem Content="运动广场东馆羽毛球场" Tag="YuehaiEast" />
                                        <ComboBoxItem Content="至快体育馆" Tag="Zhikuai" />
                                        <ComboBoxItem Content="至畅体育馆" Tag="Zhichang" />
                                        <ComboBoxItem Content="全部预设场地" Tag="AllPreset" />
                                        <ComboBoxItem Content="自定义场地" Tag="Custom" />
                                    </ComboBox>

                                    <TextBlock Classes="field-label" Text="场地" />
                                    <TextBox x:Name="ScheduleCourtsBox"
                                             Text="B1-B8 C1-C8"
                                             AcceptsReturn="True"
                                             MinHeight="78"
                                             TextWrapping="Wrap" />

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,16,0,0">
                                        <Button Classes="primary" Content="添加赛程日" Click="AddScheduleDay_Click" />
                                        <Button Grid.Column="1" Classes="secondary" Content="删除选中赛程日" Click="RemoveScheduleDay_Click" />
                                    </Grid>

                                    <TextBlock Classes="field-label" Text="赛程日列表" />
                                    <Border BorderBrush="#D8E0EC" BorderThickness="1" CornerRadius="8" MinHeight="108">
                                        <ScrollViewer MaxHeight="145">
                                            <ListBox x:Name="ScheduleDaysList"
                                                     Background="Transparent"
                                                     BorderThickness="0">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="10"
                                                                BorderBrush="#EDF1F7"
                                                                BorderThickness="0,0,0,1"
                                                                Background="#FFFFFF">
                                                            <Grid ColumnDefinitions="86,90,*" ColumnSpacing="8">
                                                                <TextBlock Text="{Binding DateText}" FontWeight="Bold" Foreground="#111827" />
                                                                <TextBlock Grid.Column="1" Text="{Binding TimeRange}" Foreground="#334155" />
                                                                <TextBlock Grid.Column="2" Text="{Binding CourtSummary}" Foreground="#64748B" TextWrapping="Wrap" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </ScrollViewer>
                                    </Border>

                                    <StackPanel x:Name="ScheduleTimingSplitPanel" IsVisible="False">
                                        <TextBlock Classes="field-label" Text="淘汰赛赛程分界线" />
                                        <TextBlock Classes="field-label" Text="分界线" />
                                        <ComboBox x:Name="ScheduleTimingBoundaryBox"
                                                  SelectedIndex="1"
                                                  SelectionChanged="ScheduleTimingBoundaryBox_SelectionChanged">
                                            <ComboBoxItem Content="不使用" Tag="0" />
                                            <ComboBoxItem Content="8强" Tag="8" />
                                            <ComboBoxItem Content="16强" Tag="16" />
                                            <ComboBoxItem Content="32强" Tag="32" />
                                        </ComboBox>

                                        <StackPanel x:Name="BeforeBoundarySettingsPanel" IsVisible="False">
                                            <TextBlock Classes="field-label" Text="分界线前设置（短赛制）" Margin="0,10,0,0" />
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                                <StackPanel>
                                                    <TextBlock Classes="field-label" Text="每场分钟" />
                                                    <TextBox x:Name="BeforeBoundaryMatchMinutesBox" Text="20" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Classes="field-label" Text="本段最多场/日" />
                                                    <ComboBox x:Name="BeforeBoundaryMaxMatchesBox" SelectedIndex="2">
                                                        <ComboBoxItem Content="1" />
                                                        <ComboBoxItem Content="2" />
                                                        <ComboBoxItem Content="3" />
                                                        <ComboBoxItem Content="4" />
                                                    </ComboBox>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock x:Name="ScheduleDefaultTimingLabel"
                                               Classes="field-label"
                                               Text="统一赛程设置" />
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <StackPanel>
                                            <TextBlock Classes="field-label" Text="每场分钟" />
                                            <TextBox x:Name="ScheduleMatchMinutesBox" Text="30" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="ScheduleMaxMatchesLabel"
                                                       Classes="field-label"
                                                       Text="每日最多场" />
                                            <ComboBox x:Name="ScheduleMaxMatchesBox" SelectedIndex="1">
                                                <ComboBoxItem Content="1" />
                                                <ComboBoxItem Content="2" />
                                                <ComboBoxItem Content="3" />
                                                <ComboBoxItem Content="4" />
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Classes="field-label" Text="自动编排策略" />
                                    <ComboBox x:Name="ScheduleAutoStrategyBox"
                                              SelectedIndex="1"
                                              SelectionChanged="ScheduleAutoStrategyBox_SelectionChanged">
                                        <ComboBoxItem Content="紧凑完成" Tag="Compact" />
                                        <ComboBoxItem Content="均衡宽松（推荐）" Tag="BalancedRelaxed" />
                                        <ComboBoxItem Content="决赛日友好" Tag="FinalsDayFriendly" />
                                    </ComboBox>
                                    <TextBlock Text="策略会影响单项目生成时每日负载和重要场次位置；切换后会按当前抽签结果重新生成赛程。"
                                               Foreground="#64748B"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0" />

                                    <TextBlock Classes="field-label" Text="高级约束提醒" />
                                    <ComboBox x:Name="ScheduleConstraintProfileBox" SelectedIndex="0">
                                        <ComboBoxItem Content="校园赛：20分钟休息，关键场次30分钟" Tag="Campus" />
                                        <ComboBoxItem Content="正式赛：30分钟休息，关键场次60分钟" Tag="Formal" />
                                        <ComboBoxItem Content="审计模式：完整推演所有晋级路径" Tag="Audit" />
                                    </ComboBox>
                                    <TextBlock Text="该设置先用于生成提醒，不会自动改变赛程；裁判长可根据提醒打开窗口拖动调整。"
                                               Foreground="#64748B"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0" />

                                    <Button Classes="primary" Content="生成赛程预览" Margin="0,14,0,0" Click="GenerateSchedule_Click" />
                                    <Button Classes="secondary" Content="导出首日材料包" Margin="0,8,0,0" Click="ExportFirstDayPackage_Click" />
                                    <Button Classes="secondary" Content="导入记录表并导出下一日材料包" Margin="0,8,0,0" Click="ImportMatchRecordAndExportNext_Click" />

                                    <TextBlock Classes="field-label" Text="完整赛程表导出为" Margin="0,14,0,0" />
                                    <ComboBox x:Name="ScheduleExportFormatBox" SelectedIndex="0">
                                        <ComboBoxItem Content="Excel" Tag="Excel" />
                                        <ComboBoxItem Content="JPG" Tag="Jpeg" />
                                        <ComboBoxItem Content="极清透明 PNG" Tag="Png" />
                                        <ComboBoxItem Content="A4 PDF" Tag="A4Pdf" />
                                        <ComboBoxItem Content="全部导出" Tag="All" />
                                    </ComboBox>
                                    <TextBlock Text="材料包会固定包含记录表、赛程安排表、带时间场地对阵表和单场计分表 PDF（每场一页横版）；上方格式只用于完整赛程表单文件导出。"
                                               Foreground="#64748B"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0" />
                                    <Button Classes="secondary" Content="导出完整赛程表" Margin="0,8,0,0" Click="ExportSchedule_Click" />
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="多项目赛程编排">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="8" Margin="0,10,0,0">
                                    <TextBlock Classes="section-title" Text="多项目赛程编排" />
                                    <TextBlock Text="把多个项目的赛事存档放在一起检查和调整。加载后可在右侧总表拖动比赛卡片，或让程序自动寻找空位。"
                                               Foreground="#64748B"
                                               TextWrapping="Wrap" />

                                    <Border Background="#F8FBFF"
                                            BorderBrush="#C7D8F0"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12"
                                            Margin="0,10,0,0">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="多项目赛程工作台"
                                                       FontWeight="SemiBold"
                                                       Foreground="#243B63" />
                                            <TextBlock Text="严重冲突和间隔过短会在总表中标红。已完成场次不会被拖动，避免和已导入赛果不一致。"
                                                       Foreground="#64748B"
                                                       TextWrapping="Wrap" />
                                            <Grid ColumnDefinitions="*,74,44" ColumnSpacing="8">
                                                <TextBlock Text="最小休息间隔"
                                                           Foreground="#64748B"
                                                           VerticalAlignment="Center" />
                                                <TextBox x:Name="CrossEventRestMinutesBox"
                                                         Grid.Column="1"
                                                         Text="20"
                                                         LostFocus="CrossEventRestMinutesBox_LostFocus" />
                                                <TextBlock Grid.Column="2"
                                                           Text="分钟"
                                                           Foreground="#64748B"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                            <TextBlock Text="自动编排策略"
                                                       Foreground="#64748B"
                                                       FontWeight="SemiBold" />
                                            <ComboBox x:Name="CrossEventSchedulingStrategyBox"
                                                      SelectedIndex="1"
                                                      SelectionChanged="CrossEventSchedulingStrategyBox_SelectionChanged">
                                                <ComboBoxItem Content="紧凑完成" Tag="Compact" />
                                                <ComboBoxItem Content="均衡宽松（推荐）" Tag="BalancedRelaxed" />
                                                <ComboBoxItem Content="决赛日友好" Tag="FinalsDayFriendly" />
                                                <ComboBoxItem Content="自定义" Tag="Custom" />
                                            </ComboBox>
                                            <Border x:Name="CrossEventCustomSchedulingPanel"
                                                    Background="#FFFFFF"
                                                    BorderBrush="#D8E0EC"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10"
                                                    IsVisible="False">
                                                <StackPanel Spacing="10">
                                                    <TextBlock Text="自定义编排参数"
                                                               FontWeight="SemiBold"
                                                               Foreground="#28104E" />
                                                    <TextBlock x:Name="CrossEventCustomHintText"
                                                               Text="加载多项目赛程后，这里会显示系统推荐参数；每次调整都会以当前控件为锚点重新平衡其他参数。"
                                                               Foreground="#64748B"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="每日目标场地负载率"
                                                               FontWeight="SemiBold"
                                                               Foreground="#243B63" />
                                                    <StackPanel x:Name="CrossEventCustomDayLoadPanel" Spacing="8" />
                                                    <CheckBox x:Name="CrossEventStageWaveBox"
                                                              Content="统一按阶段波次推进"
                                                              IsChecked="True" />
                                                    <StackPanel x:Name="CrossEventStageWavePanel" Spacing="8" />
                                                    <Button Classes="secondary"
                                                            Content="恢复推荐分布"
                                                            Click="ResetCrossEventCustomDefaults_Click" />
                                                </StackPanel>
                                            </Border>
                                            <Button Classes="primary"
                                                    Content="加载多项目赛程"
                                                    Click="LoadCrossEventScheduleBoard_Click" />
                                            <Button Classes="secondary"
                                                    Content="兼项明细"
                                                    Click="ShowCrossEventPlayerDetails_Click" />
                                            <Button Classes="secondary"
                                                    Content="保存调整到赛事存档"
                                                    Click="SaveCrossEventScheduleBoard_Click" />
                                            <Button Classes="primary"
                                                    Content="导出合并材料包"
                                                    Click="ExportCrossEventMergedMaterials_Click" />
                                            <Button Classes="primary"
                                                    Content="导出排程检查报告"
                                                    Click="ExportCrossEventConflictReport_Click" />
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FFF8E6"
                                            BorderBrush="#F2D889"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12"
                                            Margin="0,8,0,0">
                                        <TextBlock Text="严重冲突表示同一选手同时间段跨项目比赛；间隔过短表示低于最小休息间隔；同日提醒用于裁判长人工确认体能和现场调度。"
                                                   Foreground="#7B5600"
                                                   TextWrapping="Wrap" />
                                    </Border>

                                    <Border Background="#F7F3FF"
                                            BorderBrush="#DED2F8"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12"
                                            Margin="0,8,0,0">
                                        <TextBlock Text="拖拽方式：可在右侧当前比赛日内拖到目标时间和场地；打开独立窗口后可点击顶部日期标签切换日期，也可把卡片拖到日期标签跨日移动。误拖后可点“撤销调整”。排程检查报告会优先使用当前看板状态。"
                                                   Foreground="#5F5577"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <Border Classes="panel" Grid.Column="1">
                <Grid RowDefinitions="Auto,Auto,*">
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10" Margin="18,18,18,0">
                        <Border Classes="metric" Background="#ECF6FF" BorderBrush="#D2E7FB">
                            <StackPanel Spacing="4">
                                <TextBlock Text="参赛单位" Foreground="#59697E" FontWeight="SemiBold" />
                                <TextBlock x:Name="ParticipantCountText" Text="-" FontSize="26" FontWeight="Bold" Foreground="#0F172A" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Classes="metric" Background="#F0F8F1" BorderBrush="#D4EAD8">
                            <StackPanel Spacing="4">
                                <TextBlock Text="小组数" Foreground="#59697E" FontWeight="SemiBold" />
                                <TextBlock x:Name="GroupCountStatText" Text="-" FontSize="26" FontWeight="Bold" Foreground="#0F172A" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Classes="metric" Background="#FFF7E8" BorderBrush="#F2E0BE">
                            <StackPanel Spacing="4">
                                <TextBlock Text="项目" Foreground="#59697E" FontWeight="SemiBold" />
                                <TextBlock x:Name="EventKindStatText" Text="-" FontSize="26" FontWeight="Bold" Foreground="#0F172A" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Classes="metric" Background="#F6F1FF" BorderBrush="#E0D4F5">
                            <StackPanel Spacing="4">
                                <TextBlock Text="状态" Foreground="#59697E" FontWeight="SemiBold" />
                                <TextBlock x:Name="PreviewStateText" Text="待预览" FontSize="26" FontWeight="Bold" Foreground="#0F172A" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            Background="#FBFCFF"
                            BorderBrush="#E4EAF3"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="18,14,18,14">
                        <StackPanel Spacing="6">
                            <TextBlock x:Name="SummaryText" Classes="section-title" Text="尚未生成抽签预览" TextWrapping="Wrap" />
                            <Border x:Name="WarningPanel"
                                    IsVisible="False"
                                    Background="#FFF7E8"
                                    BorderBrush="#F2D39C"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,8">
                                <TextBlock x:Name="WarningText"
                                           Foreground="#8A5B00"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <TabControl x:Name="PreviewTabs" Grid.Row="2" Margin="18,0,18,18">
                        <TabItem Header="抽签结果">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <Border Width="4" Height="18" CornerRadius="2" Background="#6D2CC6" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Classes="section-title" Text="总分组" />
                                    </Grid>
                                    <ItemsControl x:Name="GroupsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="preview-row">
                                                    <Grid ColumnDefinitions="84,*" ColumnSpacing="12">
                                                        <Border Background="#EFF6FF"
                                                                BorderBrush="#D4E7FF"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Padding="8"
                                                                VerticalAlignment="Stretch">
                                                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                                                <TextBlock Text="{Binding Title}" Foreground="#0F5F9F" FontWeight="Bold" HorizontalAlignment="Center" />
                                                                <TextBlock Text="{Binding CountText}" Foreground="#526174" FontSize="12" HorizontalAlignment="Center" />
                                                            </StackPanel>
                                                        </Border>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Body}"
                                                                   Foreground="#111827"
                                                                   TextWrapping="Wrap"
                                                                   LineHeight="22" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <Border Width="4" Height="18" CornerRadius="2" Background="#F4B83D" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Classes="section-title" Text="首轮赛" />
                                    </Grid>
                                    <ItemsControl x:Name="RoundOneList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="preview-row">
                                                    <Grid ColumnDefinitions="84,*" ColumnSpacing="12">
                                                        <Border Background="#FFF7E8"
                                                                BorderBrush="#F3DEB7"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Padding="8">
                                                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                                                <TextBlock Text="{Binding Title}" Foreground="#8A5B00" FontWeight="Bold" HorizontalAlignment="Center" />
                                                                <TextBlock Text="{Binding CountText}" Foreground="#776144" FontSize="12" HorizontalAlignment="Center" />
                                                            </StackPanel>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="{Binding Body}" Foreground="#111827" TextWrapping="Wrap" LineHeight="22" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <Border Width="4" Height="18" CornerRadius="2" Background="#31A46C" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Classes="section-title" Text="轮空 / 直接晋级" />
                                    </Grid>
                                    <ItemsControl x:Name="ByeList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="preview-row">
                                                    <Grid ColumnDefinitions="84,*" ColumnSpacing="12">
                                                        <Border Background="#EFF8F2"
                                                                BorderBrush="#D4EADC"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Padding="8">
                                                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                                                <TextBlock Text="{Binding Title}" Foreground="#2C7350" FontWeight="Bold" HorizontalAlignment="Center" />
                                                                <TextBlock Text="{Binding CountText}" Foreground="#526B5E" FontSize="12" HorizontalAlignment="Center" />
                                                            </StackPanel>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="{Binding Body}" Foreground="#111827" TextWrapping="Wrap" LineHeight="22" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="赛程预览">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto"
                                          Margin="0,10,0,0">
                                <StackPanel Spacing="12">
                                    <Border Background="#F8FAFC"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12">
                                        <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="12">
                                            <Button Classes="secondary"
                                                    Width="88"
                                                    Content="打开窗口"
                                                    Click="OpenScheduleBoardWindow_Click" />
                                            <Button x:Name="ScheduleConstraintButton"
                                                    Grid.Column="1"
                                                    Classes="secondary"
                                                    Width="88"
                                                    Content="查看提醒"
                                                    IsEnabled="False"
                                                    Click="ShowScheduleConstraintDetails_Click" />
                                            <Button x:Name="ScheduleUndoButton"
                                                    Grid.Column="2"
                                                    Classes="secondary"
                                                    Width="112"
                                                    Content="撤销调整"
                                                    IsEnabled="False"
                                                    Click="UndoSingleScheduleMove_Click" />
                                            <TextBlock x:Name="ScheduleSummaryText"
                                                       Grid.Column="3"
                                                       Text="尚未生成赛程"
                                                       Foreground="#35445D"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                     </Border>
                                    <StackPanel MinWidth="1120">
                                        <Border Background="#EDE1FC"
                                                BorderBrush="#D8C7F4"
                                                BorderThickness="1"
                                                Padding="10,8">
                                            <Grid ColumnDefinitions="56,76,112,96,82,104,146,*,*,156" ColumnSpacing="8">
                                                <TextBlock Text="序号" FontWeight="Bold" Foreground="#32116D" TextAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="状态" FontWeight="Bold" Foreground="#32116D" TextAlignment="Center" />
                                                <TextBlock Grid.Column="2" Text="日期/比赛日" FontWeight="Bold" Foreground="#32116D" TextAlignment="Center" />
                                                <TextBlock Grid.Column="3" Text="时间" FontWeight="Bold" Foreground="#32116D" TextAlignment="Center" />
                                                <TextBlock Grid.Column="4" Text="场地" FontWeight="Bold" Foreground="#32116D" TextAlignment="Center" />
                                                <TextBlock Grid.Column="5" Text="组别" FontWeight="Bold" Foreground="#32116D" TextAlignment="Center" />
                                                <TextBlock Grid.Column="6" Text="阶段/场次" FontWeight="Bold" Foreground="#32116D" TextAlignment="Center" />
                                                <TextBlock Grid.Column="7" Text="选手/队伍A" FontWeight="Bold" Foreground="#32116D" TextAlignment="Center" />
                                                <TextBlock Grid.Column="8" Text="选手/队伍B" FontWeight="Bold" Foreground="#32116D" TextAlignment="Center" />
                                                <TextBlock Grid.Column="9" Text="备注" FontWeight="Bold" Foreground="#32116D" TextAlignment="Center" />
                                            </Grid>
                                        </Border>
                                        <ItemsControl x:Name="ScheduleList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding BackgroundBrush}"
                                                            BorderBrush="{Binding BorderBrush}"
                                                            BorderThickness="1,0,1,1"
                                                            Padding="10,8">
                                                        <Grid ColumnDefinitions="56,76,112,96,82,104,146,*,*,156" ColumnSpacing="8">
                                                            <TextBlock Text="{Binding Order}" Foreground="#111827" FontWeight="SemiBold" TextAlignment="Center" VerticalAlignment="Center" />
                                                            <Border Grid.Column="1"
                                                                    Background="{Binding BadgeBrush}"
                                                                    CornerRadius="6"
                                                                    Padding="6,4"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Status}"
                                                                           Foreground="{Binding BadgeForeground}"
                                                                           FontWeight="Bold"
                                                                           TextAlignment="Center" />
                                                            </Border>
                                                            <TextBlock Grid.Column="2" Text="{Binding DayLabel}" Foreground="#111827" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="3" Text="{Binding TimeRange}" Foreground="#111827" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="4" Text="{Binding Court}" Foreground="#111827" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="5" Text="{Binding GroupName}" Foreground="#28104E" FontWeight="Bold" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                            <StackPanel Grid.Column="6" Spacing="2" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Phase}" Foreground="#111827" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                                <TextBlock Text="{Binding MatchName}" Foreground="#64748B" FontSize="12" TextWrapping="Wrap" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="7" Text="{Binding SideA}" Foreground="#111827" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="8" Text="{Binding SideB}" Foreground="#111827" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="9" Text="{Binding Note}" Foreground="#64748B" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem x:Name="CrossEventPreviewTab" Header="多项目赛程">
                            <Grid RowDefinitions="Auto,*" Margin="0,6,0,0">
                                <Border Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10">
                                    <Grid ColumnDefinitions="*,Auto,180" ColumnSpacing="12">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="多项目赛程总览"
                                                       FontWeight="Bold"
                                                       Foreground="#28104E" />
                                            <TextBlock x:Name="CrossEventBoardSummaryText"
                                                       Text="尚未加载多项目赛程。请先在左侧选择至少两个赛事存档。"
                                                       Foreground="#64748B"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Bottom"
                                                    Spacing="8">
                                            <Button x:Name="CrossEventOpenWindowButton"
                                                    Classes="secondary"
                                                    Width="88"
                                                    Content="打开窗口"
                                                    Click="OpenCrossEventBoardWindow_Click" />
                                            <Button x:Name="CrossEventUndoButton"
                                                    Classes="secondary"
                                                    Width="112"
                                                    Content="撤销调整"
                                                    IsEnabled="False"
                                                    Click="UndoCrossEventScheduleMove_Click" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="5">
                                            <TextBlock Text="显示比赛日"
                                                       Foreground="#64748B"
                                                       FontWeight="SemiBold" />
                                            <ComboBox x:Name="CrossEventDayBox"
                                                      SelectionChanged="CrossEventDayBox_SelectionChanged" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Border Grid.Row="1"
                                        Background="#FBFCFF"
                                        BorderBrush="#D8E0EC"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,8,0,0">
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                        <Grid x:Name="CrossEventScheduleBoardGrid"
                                              Margin="8"
                                              MinWidth="760"
                                              MinHeight="420" />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="StatusBar"
                Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#DCE3EF"
                BorderThickness="0,1,0,0"
                Padding="24,11">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Border x:Name="StatusDot"
                        Width="9"
                        Height="9"
                        CornerRadius="5"
                        Background="#19A974"
                        VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Grid.Column="1"
                           Text="准备就绪。跨平台桌面版已支持抽签、赛程、多项目编排、赛事存档和材料包导出。"
                           Foreground="#41506A"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>
    </Grid>
</Window>
